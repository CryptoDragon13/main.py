# انسخ الملف ده لاسم .env واملأ القيم الحقيقية بتاعتك
# لو بتستخدم استضافة (Railway/Render/إلخ) حط نفس القيم دي في قسم Environment Variables بتاع لوحة التحكم بدل ما تعمل .env

# توكن البوت من @BotFather
BOT_TOKEN=1234567890:AAExampleTokenExampleTokenExample

# يوزر البوت من غير @ (لازم يكون مطابق للبوت الحقيقي عشان رابط الدعوة يشتغل)
BOT_USERNAME=@Thepenguin0_Bot

# آيديز الأدمن مفصولة بفاصلة (من غير مسافات) - جرب @userinfobot عشان تعرف آيدي حسابك
ADMIN_IDS=868999453

# مسار قاعدة البيانات (سيبها زي ما هي لو مش عارف)
DB_PATH=atf_bot.sqlite3

# اتركها false لو هتشغل البوت كـ Background Worker (Railway worker / VPS / systemd / pm2)
# وحطها true بس لو الاستضافة محتاجة "Web Service" بيسمع على بورت (زي Render Web Service المجاني)
USE_WEBHOOK=false

# لازم https ومطابق لدومين الاستضافة بتاعتك - يتفعل بس لو USE_WEBHOOK=true
# مثال: https://your-app-name.up.railway.app  أو  https://your-app.onrender.com
WEBHOOK_BASE_URL=

# البورت - أغلب الاستضافات بتحطه تلقائي في متغير PORT، سيبه زي ما هو
PORT=8080
